# ── Application ────────────────────────────────────────────────────────────
APP_NAME=Productivity Agent API
LOG_LEVEL=INFO
STORE_PATH=data/store.json

# ── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
RELOAD=false

# ── OpenAI / LangChain ──────────────────────────────────────────────────────
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.0

# ── Agent Prompts ───────────────────────────────────────────────────────────
# AGENT_SYSTEM_PROMPT=...   # override the full system prompt if needed
# AGENT_USER_PROMPT_TEMPLATE=...
# AGENT_NO_PENDING_MESSAGE=No pending tasks.

# ── Middleware / Logging ────────────────────────────────────────────────────
MIDDLEWARE_LOGGER_NAME=app.middleware
LOG_EVENT_REQUEST=request
LOG_EVENT_RESPONSE=response

# ── Error Codes & Messages ──────────────────────────────────────────────────
ERROR_CODE_INTERNAL=INTERNAL_ERROR
ERROR_CODE_NOT_FOUND=TASK_NOT_FOUND
ERROR_CODE_STORE_CORRUPTED=STORE_CORRUPTED
ERROR_CODE_VALIDATION=VALIDATION_ERROR
ERROR_MSG_INTERNAL=An unexpected error occurred
ERROR_MSG_STORE_CORRUPTED=Data store is corrupted
ERROR_MSG_VALIDATION=Request validation failed

# ── Router Config ───────────────────────────────────────────────────────────
TASKS_PREFIX=/tasks
TASKS_TAG=tasks
AGENT_PREFIX=/agent
AGENT_TAG=agent
AGENT_DECISION_PATH=/decision

# ── Task Model ──────────────────────────────────────────────────────────────
TASK_TITLE_MAX_LENGTH=200
TASK_PRIORITY_MIN=1
TASK_PRIORITY_MAX=5
TASK_TITLE_EMPTY_ERROR=title must not be empty or whitespace

# ── Exception Messages ──────────────────────────────────────────────────────
EXC_TASK_NOT_FOUND_TEMPLATE=Task {task_id} not found
EXC_TASK_ALREADY_COMPLETED_TEMPLATE=Task {task_id} is already completed
ERROR_CODE_TASK_ALREADY_COMPLETED=TASK_ALREADY_COMPLETED

# ── PostgreSQL / worky ──────────────────────────────────────────────────────
PG_HOST=62.171.191.132
PG_PORT=5437
PG_DATABASE=worky
PG_USER=postgres
PG_PASSWORD=W0rky_Pr0d_2024_S3cur3!
PG_MIN_CONNECTIONS=2
PG_MAX_CONNECTIONS=10
