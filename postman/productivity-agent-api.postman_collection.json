{
  "info": {
    "name": "Productivity Agent API",
    "description": "Collection for testing the Productivity Agent API. Set the `base_url` variable to your server address before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "task_id",
      "value": "",
      "type": "string",
      "description": "Auto-populated after Create Task runs"
    }
  ],
  "item": [
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task — valid",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Response has id', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.be.a('string');",
                  "  pm.collectionVariables.set('task_id', body.id);",
                  "});",
                  "pm.test('completed is false', () => pm.expect(pm.response.json().completed).to.be.false);",
                  "pm.test('created_at is present', () => pm.expect(pm.response.json().created_at).to.be.a('string'));",
                  "pm.test('completed_at is null', () => pm.expect(pm.response.json().completed_at).to.be.null);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Write unit tests\",\n  \"description\": \"Cover all service layer functions\",\n  \"priority\": 5,\n  \"tags\": [\"testing\", \"backend\"],\n  \"duration_hours\": 1.5,\n  \"deadline\": \"2026-03-25T18:00:00\"\n}"
            },
            "url": { "raw": "{{base_url}}/tasks/", "host": ["{{base_url}}"], "path": ["tasks", ""] }
          }
        },
        {
          "name": "List Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is an array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "pm.test('Array is non-empty after create', () => pm.expect(pm.response.json().length).to.be.at.least(1));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/tasks/", "host": ["{{base_url}}"], "path": ["tasks", ""] }
          }
        },
        {
          "name": "Get Task — valid",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('id matches', () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('task_id')));",
                  "pm.test('title is present', () => pm.expect(pm.response.json().title).to.be.a('string').and.not.empty);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["tasks", "{{task_id}}"]
            }
          }
        },
        {
          "name": "Get Task — not found (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404', () => pm.response.to.have.status(404));",
                  "pm.test('error_code is TASK_NOT_FOUND', () => pm.expect(pm.response.json().error_code).to.eql('TASK_NOT_FOUND'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tasks/00000000-0000-0000-0000-000000000000",
              "host": ["{{base_url}}"],
              "path": ["tasks", "00000000-0000-0000-0000-000000000000"]
            }
          }
        },
